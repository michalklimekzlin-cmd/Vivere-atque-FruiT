<!DOCTYPE html>
<html lang="cs">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Glyph</title>

<style>
*{
    box-sizing:border-box;
}

html,body{
    margin:0;
    height:100%;
    background:#111;
    color:#eee;
    font-family:system-ui,sans-serif;
}

textarea{
    width:100%;
    height:100%;
    border:none;
    outline:none;
    resize:none;
    padding:20px;
    background:#111;
    color:#eee;
    font-size:18px;
    line-height:1.6;
    caret-color:#fff;
}
</style>

</head>
<body>

<textarea id="glyph" placeholder="Piš..."></textarea>

<script>
const text=document.getElementById("glyph");

text.value=localStorage.getItem("glyph")||"";

text.addEventListener("input",()=>{
    localStorage.setItem("glyph",text.value);
});
</script>

</body>
</html>