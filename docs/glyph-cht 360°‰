"use strict";

const APP_NAME = "Glyph CHT 360°‰";
const FORMAT = "glyph-cht-360-registry";
const VERSION = 1;
const STORAGE_KEY = "glyph-cht-360.registry.v1";
const SETTINGS_KEY = "glyph-cht-360.settings.v1";
const CONTROL_CHARACTER = /[\u0000-\u0008\u000B\u000C\u000E-\u001F\u007F-\u009F]/u;
const POSSIBLE_MOJIBAKE = /(?:Ã.|Â.|â.{1,2}|ð.{1,2})/u;

const worlds = {
  earth: "Paměť",
  language: "Jazyk",
  game: "Hra",
  control: "Řízení",
  free: "Mimo světy"
};

const statusLabels = {
  "návrh": "Návrh",
  "schváleno": "Schváleno",
  archiv: "Archiv"
};

const dom = {
  glyphList: document.getElementById("glyphList"),
  searchInput: document.getElementById("searchInput"),
  statusFilter: document.getElementById("statusFilter"),
  worldFilter: document.getElementById("worldFilter"),
  newGlyph: document.getElementById("newGlyph"),
  glyphForm: document.getElementById("glyphForm"),
  glyphId: document.getElementById("glyphId"),
  glyphSymbol: document.getElementById("glyphSymbol"),
  glyphName: document.getElementById("glyphName"),
  glyphWorld: document.getElementById("glyphWorld"),
  glyphRole: document.getElementById("glyphRole"),
  glyphWeight: document.getElementById("glyphWeight"),
  glyphStatus: document.getElementById("glyphStatus"),
  glyphMeaning: document.getElementById("glyphMeaning"),
  glyphTags: document.getElementById("glyphTags"),
  editorTitle: document.getElementById("editorTitle"),
  formState: document.getElementById("formState"),
  formNotice: document.getElementById("formNotice"),
  archiveGlyph: document.getElementById("archiveGlyph"),
  deleteGlyph: document.getElementById("deleteGlyph"),
  generatorLength: document.getElementById("generatorLength"),
  generatorLengthValue: document.getElementById("generatorLengthValue"),
  generatorScope: document.getElementById("generatorScope"),
  avoidRepeats: document.getElementById("avoidRepeats"),
  generateGlyph: document.getElementById("generateGlyph"),
  generatedGlyph: document.getElementById("generatedGlyph"),
  generatedMeta: document.getElementById("generatedMeta"),
  copyGenerated: document.getElementById("copyGenerated"),
  sendToEditor: document.getElementById("sendToEditor"),
  runAudit: document.getElementById("runAudit"),
  auditList: document.getElementById("auditList"),
  registryCount: document.getElementById("registryCount"),
  approvedCount: document.getElementById("approvedCount"),
  auditCount: document.getElementById("auditCount"),
  auditNote: document.getElementById("auditNote"),
  storageState: document.getElementById("storageState"),
  storageNote: document.getElementById("storageNote"),
  statusLine: document.getElementById("statusLine"),
  exportRegistry: document.getElementById("exportRegistry"),
  importRegistry: document.getElementById("importRegistry"),
  openGuide: document.getElementById("openGuide"),
  closeGuide: document.getElementById("closeGuide"),
  guideDialog: document.getElementById("guideDialog")
};

const state = {
  registry: loadRegistry(),
  selectedId: null,
  generated: null,
  audit: [],
  settings: loadSettings(),
  lastBackupAt: null,
  storageAvailable: true
};

initialize();

function initialize() {
  applySettings();
  bindEvents();
  runAudit();
  renderAll();
  registerServiceWorker();
}

function bindEvents() {
  dom.searchInput.addEventListener("input", renderGlyphList);
  dom.statusFilter.addEventListener("change", renderGlyphList);
  dom.worldFilter.addEventListener("change", renderGlyphList);
  dom.newGlyph.addEventListener("click", startNewGlyph);
  dom.glyphList.addEventListener("click", selectGlyphFromList);
  dom.glyphForm.addEventListener("submit", saveGlyph);
  dom.archiveGlyph.addEventListener("click", archiveSelectedGlyph);
  dom.deleteGlyph.addEventListener("click", deleteSelectedGlyph);
  dom.glyphSymbol.addEventListener("input", previewGlyphCheck);
  dom.generatorLength.addEventListener("input", updateGeneratorLength);
  dom.generatorScope.addEventListener("change", saveSettings);
  dom.avoidRepeats.addEventListener("change", saveSettings);
  dom.generateGlyph.addEventListener("click", generateGlyph);
  dom.copyGenerated.addEventListener("click", copyGeneratedGlyph);
  dom.sendToEditor.addEventListener("click", sendGeneratedToEditor);
  dom.runAudit.addEventListener("click", () => {
    runAudit();
    renderAudit();
    renderDrums();
    setStatus("Kontrola registru je hotová.");
  });
  dom.exportRegistry.addEventListener("click", exportRegistry);
  dom.importRegistry.addEventListener("change", importRegistry);
  dom.openGuide.addEventListener("click", () => dom.guideDialog.showModal());
  dom.closeGuide.addEventListener("click", () => dom.guideDialog.close());
  dom.guideDialog.addEventListener("click", (event) => {
    if (event.target === dom.guideDialog) dom.guideDialog.close();
  });
}

function loadRegistry() {
  const empty = createEmptyRegistry();
  try {
    const stored = localStorage.getItem(STORAGE_KEY);
    if (!stored) return empty;
    const parsed = JSON.parse(stored);
    if (!parsed || !Array.isArray(parsed.glyphs)) return empty;
    return {
      ...empty,
      ...parsed,
      format: FORMAT,
      version: VERSION,
      glyphs: parsed.glyphs.map(hydrateGlyph).filter(Boolean)
    };
  } catch (error) {
    return empty;
  }
}

function loadSettings() {
  const fallback = { length: 3, scope: "approved", avoidRepeats: true };
  try {
    const stored = JSON.parse(localStorage.getItem(SETTINGS_KEY));
    return { ...fallback, ...(stored || {}) };
  } catch (error) {
    return fallback;
  }
}

function createEmptyRegistry() {
  const now = new Date().toISOString();
  return {
    format: FORMAT,
    version: VERSION,
    app: APP_NAME,
    createdAt: now,
    updatedAt: now,
    glyphs: []
  };
}

function hydrateGlyph(raw) {
  if (!raw || typeof raw !== "object") return null;
  const glyph = String(raw.glyph || "").trim();
  if (!glyph) return null;
  return {
    id: String(raw.id || makeId()),
    glyph,
    glyphNfc: normalizeUnicode(glyph),
    name: String(raw.name || "").trim(),
    meaning: String(raw.meaning || "").trim(),
    world: Object.hasOwn(worlds, raw.world) ? raw.world : "free",
    role: String(raw.role || "").trim(),
    weight: clamp(Number(raw.weight) || 3, 1, 5),
    status: Object.hasOwn(statusLabels, raw.status) ? raw.status : "návrh",
    tags: Array.isArray(raw.tags) ? raw.tags.map((tag) => String(tag).trim()).filter(Boolean) : parseTags(raw.tags),
    createdAt: isDate(raw.createdAt) ? raw.createdAt : new Date().toISOString(),
    updatedAt: isDate(raw.updatedAt) ? raw.updatedAt : new Date().toISOString()
  };
}

function applySettings() {
  dom.generatorLength.value = String(clamp(Number(state.settings.length) || 3, 1, 12));
  dom.generatorScope.value = state.settings.scope === "all" ? "all" : "approved";
  dom.avoidRepeats.checked = Boolean(state.settings.avoidRepeats);
  updateGeneratorLength();
}

function saveSettings() {
  state.settings = {
    length: Number(dom.generatorLength.value),
    scope: dom.generatorScope.value,
    avoidRepeats: dom.avoidRepeats.checked
  };
  try {
    localStorage.setItem(SETTINGS_KEY, JSON.stringify(state.settings));
  } catch (error) {
    state.storageAvailable = false;
  }
}

function updateGeneratorLength() {
  dom.generatorLengthValue.value = dom.generatorLength.value;
  saveSettings();
}

function persistRegistry() {
  state.registry.updatedAt = new Date().toISOString();
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state.registry));
    state.storageAvailable = true;
    return true;
  } catch (error) {
    state.storageAvailable = false;
    setStatus("Registr se nepodařilo uložit do místní paměti.", "error");
    return false;
  }
}

function renderAll() {
  renderGlyphList();
  renderEditor();
  renderGenerated();
  renderAudit();
  renderDrums();
}

function renderGlyphList() {
  const query = normalizeSearch(dom.searchInput.value);
  const selectedStatus = dom.statusFilter.value;
  const selectedWorld = dom.worldFilter.value;
  const glyphs = [...state.registry.glyphs]
    .filter((entry) => selectedStatus === "all" || entry.status === selectedStatus)
    .filter((entry) => selectedWorld === "all" || entry.world === selectedWorld)
    .filter((entry) => !query || searchableGlyph(entry).includes(query))
    .sort(sortGlyphs);

  if (!glyphs.length) {
    const emptyMessage = state.registry.glyphs.length
      ? "Tomu filtru zatím neodpovídá žádný Glyph."
      : "Zatím je tu prázdno. První Glyph si určíš ty — tlačítkem +.";
    dom.glyphList.innerHTML = `<p class="empty-list">${escapeHtml(emptyMessage)}</p>`;
    return;
  }

  dom.glyphList.innerHTML = glyphs.map((entry) => {
    const selectedClass = entry.id === state.selectedId ? " is-selected" : "";
    const name = entry.name || "Bez názvu";
    const meta = [worlds[entry.world], entry.role || "bez role"].join(" · ");
    return `
      <button class="glyph-item${selectedClass}" type="button" data-glyph-id="${escapeAttribute(entry.id)}" aria-label="Otevřít Glyph ${escapeAttribute(name)}">
        <span class="glyph-mark">${escapeHtml(entry.glyph)}</span>
        <span class="glyph-copy">
          <span class="glyph-name">${escapeHtml(name)}</span>
          <span class="glyph-meta">${escapeHtml(meta)}</span>
        </span>
        <span class="badge status-${escapeAttribute(entry.status)}">${escapeHtml(statusLabels[entry.status])}</span>
      </button>`;
  }).join("");
}

function renderEditor() {
  const entry = getSelectedGlyph();
  const isEditing = Boolean(entry);

  dom.editorTitle.textContent = isEditing ? (entry.name || "Upravit Glyph") : "Nový Glyph";
  dom.formState.textContent = isEditing ? `upraveno ${formatShortDate(entry.updatedAt)}` : "neuloženo";
  dom.archiveGlyph.disabled = !isEditing || entry.status === "archiv";
  dom.deleteGlyph.disabled = !isEditing;

  if (!isEditing) {
    dom.glyphForm.reset();
    dom.glyphId.value = "";
    dom.glyphWorld.value = "free";
    dom.glyphWeight.value = "3";
    dom.glyphStatus.value = "návrh";
    setFormNotice("", "");
    return;
  }

  dom.glyphId.value = entry.id;
  dom.glyphSymbol.value = entry.glyph;
  dom.glyphName.value = entry.name;
  dom.glyphWorld.value = entry.world;
  dom.glyphRole.value = entry.role;
  dom.glyphWeight.value = String(entry.weight);
  dom.glyphStatus.value = entry.status;
  dom.glyphMeaning.value = entry.meaning;
  dom.glyphTags.value = entry.tags.join(", ");
  previewGlyphCheck();
}

function renderGenerated() {
  const result = state.generated;
  dom.copyGenerated.disabled = !result;
  dom.sendToEditor.disabled = !result;

  if (!result) {
    dom.generatedGlyph.textContent = "—";
    dom.generatedMeta.textContent = "Až vložíš své Glyphy, generátor bude kombinovat pouze je.";
    return;
  }

  dom.generatedGlyph.textContent = result.glyph;
  const names = result.entries.map((entry) => entry.name || entry.glyph).join(" · ");
  dom.generatedMeta.textContent = `Sestaveno z: ${names}. Zůstává to jen návrhem, dokud to sám neuložíš.`;
}

function renderAudit() {
  const issues = state.audit;
  if (!issues.length) {
    const message = state.registry.glyphs.length
      ? "Kontrola nenašla žádnou známou chybu."
      : "Registr je prázdný; kontrola bude připravená na první znak.";
    dom.auditList.innerHTML = `<li class="audit-item"><span class="audit-kind ok">ČISTÉ</span><div><strong>${escapeHtml(message)}</strong><p>Kontrola nic nemění automaticky.</p></div></li>`;
    return;
  }

  dom.auditList.innerHTML = issues.map((issue) => `
    <li class="audit-item">
      <span class="audit-kind ${escapeAttribute(issue.kind)}">${escapeHtml(issue.kind === "error" ? "CHYBA" : "POZOR")}</span>
      <div>
        <strong>${escapeHtml(issue.title)}</strong>
        <p>${escapeHtml(issue.message)}</p>
      </div>
    </li>`).join("");
}

function renderDrums() {
  const all = state.registry.glyphs.length;
  const approved = state.registry.glyphs.filter((entry) => entry.status === "schváleno").length;
  const errors = state.audit.filter((issue) => issue.kind === "error").length;
  const warnings = state.audit.filter((issue) => issue.kind === "warning").length;

  dom.registryCount.textContent = String(all);
  dom.approvedCount.textContent = String(approved);
  dom.auditCount.textContent = errors ? formatIssueCount(errors) : warnings ? `${warnings} pozor` : "Čisté";
  dom.auditNote.textContent = errors ? "je potřeba projít" : warnings ? "ručně ověřit" : all ? "registr prošel" : "čeká na první Glyph";
  dom.storageState.textContent = state.storageAvailable ? "Lokální" : "Pozor";
  dom.storageNote.textContent = state.storageAvailable
    ? state.lastBackupAt ? `záloha ${formatShortDate(state.lastBackupAt)}` : "je připravena"
    : "uložení se nepodařilo";
}

function startNewGlyph() {
  state.selectedId = null;
  renderGlyphList();
  renderEditor();
  dom.glyphSymbol.focus();
  setStatus("Editor je připravený na nový Glyph.");
}

function selectGlyphFromList(event) {
  const button = event.target.closest("[data-glyph-id]");
  if (!button) return;
  state.selectedId = button.dataset.glyphId;
  renderGlyphList();
  renderEditor();
  setStatus("Glyph je otevřený v editoru.");
}

function getSelectedGlyph() {
  return state.registry.glyphs.find((entry) => entry.id === state.selectedId) || null;
}

function saveGlyph(event) {
  event.preventDefault();
  const existing = getSelectedGlyph();
  const candidate = hydrateGlyph({
    id: existing?.id || makeId(),
    glyph: dom.glyphSymbol.value,
    name: dom.glyphName.value,
    meaning: dom.glyphMeaning.value,
    world: dom.glyphWorld.value,
    role: dom.glyphRole.value,
    weight: dom.glyphWeight.value,
    status: dom.glyphStatus.value,
    tags: parseTags(dom.glyphTags.value),
    createdAt: existing?.createdAt || new Date().toISOString(),
    updatedAt: new Date().toISOString()
  });

  if (!candidate) {
    setFormNotice("Vlož alespoň jeden viditelný znak.", "error");
    return;
  }

  const issues = inspectGlyph(candidate, state.registry.glyphs.filter((entry) => entry.id !== candidate.id));
  const errors = issues.filter((issue) => issue.kind === "error");
  if (errors.length) {
    setFormNotice(errors.map((issue) => issue.message).join(" "), "error");
    return;
  }

  const index = state.registry.glyphs.findIndex((entry) => entry.id === candidate.id);
  if (index >= 0) state.registry.glyphs[index] = candidate;
  else state.registry.glyphs.push(candidate);

  state.selectedId = candidate.id;
  persistRegistry();
  runAudit();
  renderAll();
  const warnings = issues.filter((issue) => issue.kind === "warning");
  setFormNotice(warnings.length ? `Uloženo. Pozor: ${warnings[0].message}` : "Uloženo do tvého registru.", warnings.length ? "warning" : "");
  setStatus(`Glyph „${candidate.name || candidate.glyph}“ je uložený.`);
}

function archiveSelectedGlyph() {
  const entry = getSelectedGlyph();
  if (!entry) return;
  entry.status = "archiv";
  entry.updatedAt = new Date().toISOString();
  persistRegistry();
  runAudit();
  renderAll();
  setStatus("Glyph byl přesunutý do archivu. Zůstává v záloze.");
}

function deleteSelectedGlyph() {
  const entry = getSelectedGlyph();
  if (!entry) return;
  const label = entry.name || entry.glyph;
  if (!window.confirm(`Opravdu smazat „${label}“? Nejdřív si případně vytvoř zálohu.`)) return;
  state.registry.glyphs = state.registry.glyphs.filter((item) => item.id !== entry.id);
  state.selectedId = null;
  state.generated = null;
  persistRegistry();
  runAudit();
  renderAll();
  setStatus("Glyph byl odstraněný z tohoto zařízení.");
}

function previewGlyphCheck() {
  const raw = dom.glyphSymbol.value;
  if (!raw.trim()) {
    setFormNotice("", "");
    return;
  }
  const draft = hydrateGlyph({ glyph: raw, status: dom.glyphStatus.value });
  const issues = draft ? inspectGlyph(draft, state.registry.glyphs.filter((entry) => entry.id !== state.selectedId)) : [];
  const error = issues.find((issue) => issue.kind === "error");
  const warning = issues.find((issue) => issue.kind === "warning");
  if (error) setFormNotice(error.message, "error");
  else if (warning) setFormNotice(`Kontrola: ${warning.message}`, "warning");
  else setFormNotice("Znak vypadá v pořádku. Uložení je vždy na tobě.", "");
}

function setFormNotice(message, kind) {
  dom.formNotice.textContent = message;
  dom.formNotice.className = `form-notice${kind ? ` ${kind}` : ""}`;
}

function runAudit() {
  const issues = [];
  state.registry.glyphs.forEach((entry) => {
    inspectGlyph(entry, state.registry.glyphs.filter((other) => other.id !== entry.id)).forEach((issue) => {
      issues.push({
        ...issue,
        title: `${entry.name || entry.glyph}: ${issue.title}`
      });
    });
  });
  state.audit = issues;
}

function inspectGlyph(entry, others) {
  const issues = [];
  const glyph = entry.glyph;
  const normalized = normalizeUnicode(glyph);
  if (!glyph.trim()) {
    issues.push(issue("error", "Prázdný Glyph", "Glyph nemůže být prázdný."));
    return issues;
  }
  if (glyph.includes("\uFFFD")) {
    issues.push(issue("error", "Poškozený znak", "Je tu náhradní znak �. Vrať se ke zdrojovému Glyphu a vlož jej znovu."));
  }
  if (CONTROL_CHARACTER.test(glyph)) {
    issues.push(issue("error", "Skrytý řídicí znak", "Glyph obsahuje neviditelný řídicí znak. Systém jej nikdy neodstraní sám; zkontroluj ho ručně."));
  }
  if (glyph !== normalized) {
    issues.push(issue("warning", "Složený zápis Unicode", "Tento Glyph má jinou NFC podobu. Zachovávám původní zápis, ale při sdílení jej ručně zkontroluj."));
  }
  if (hasPrivateUseCharacter(glyph)) {
    issues.push(issue("warning", "Soukromý kód znaku", "Glyph používá soukromou oblast Unicode. Mimo vlastní font se může zobrazit jinak nebo vůbec."));
  }
  if (POSSIBLE_MOJIBAKE.test(glyph)) {
    issues.push(issue("warning", "Možná stopa špatného kódování", "Znak obsahuje sled typický pro chybné načtení UTF‑8. Může být záměrný, proto jej pouze označuji k ruční kontrole."));
  }
  if ([...glyph].length > 48) {
    issues.push(issue("warning", "Velmi dlouhý Glyph", "Glyph má přes 48 znaků. Je platný, ale v některých rozhraních může být hůře čitelný."));
  }
  const duplicate = others.find((other) => other.glyphNfc === normalized);
  if (duplicate) {
    issues.push(issue("error", "Duplicitní Glyph", `Stejný Glyph už máš uložený jako „${duplicate.name || duplicate.glyph}“.`));
  }
  if (entry.status === "schváleno" && !entry.meaning) {
    issues.push(issue("warning", "Schváleno bez významu", "Glyph je schválený, ale zatím nemá zapsaný význam."));
  }
  return issues;
}

function issue(kind, title, message) {
  return { kind, title, message };
}

function generateGlyph() {
  const scope = dom.generatorScope.value;
  const candidates = state.registry.glyphs.filter((entry) => {
    if (entry.status === "archiv") return false;
    return scope === "all" || entry.status === "schváleno";
  });
  if (!candidates.length) {
    state.generated = null;
    renderGenerated();
    setStatus(scope === "approved"
      ? "Nejdřív schval alespoň jeden svůj Glyph pro generátor."
      : "Nejdřív ulož alespoň jeden svůj Glyph.", "warning");
    return;
  }

  const length = clamp(Number(dom.generatorLength.value), 1, 12);
  const entries = [];
  let previousId = null;
  for (let index = 0; index < length; index += 1) {
    const picked = weightedPick(candidates, dom.avoidRepeats.checked ? previousId : null);
    entries.push(picked);
    previousId = picked.id;
  }
  state.generated = {
    glyph: entries.map((entry) => entry.glyph).join(""),
    entries,
    createdAt: new Date().toISOString()
  };
  renderGenerated();
  setStatus("Vznikla nová kombinace z tvých Glyphů. Nic se samo neuložilo.");
}

function weightedPick(entries, avoidId) {
  const available = entries.filter((entry) => entry.id !== avoidId);
  const pool = available.length ? available : entries;
  const total = pool.reduce((sum, entry) => sum + clamp(Number(entry.weight) || 3, 1, 5), 0);
  let point = Math.random() * total;
  for (const entry of pool) {
    point -= clamp(Number(entry.weight) || 3, 1, 5);
    if (point <= 0) return entry;
  }
  return pool[pool.length - 1];
}

async function copyGeneratedGlyph() {
  if (!state.generated) return;
  const copied = await copyText(state.generated.glyph);
  setStatus(copied ? "Kombinace je zkopírovaná." : "Kopírování se nepodařilo. Glyph můžeš označit ručně.", copied ? "" : "warning");
}

function sendGeneratedToEditor() {
  if (!state.generated) return;
  state.selectedId = null;
  renderGlyphList();
  renderEditor();
  dom.glyphSymbol.value = state.generated.glyph;
  dom.glyphName.value = "";
  dom.glyphMeaning.value = "";
  dom.glyphStatus.value = "návrh";
  previewGlyphCheck();
  dom.glyphName.focus();
  setStatus("Kombinace je v editoru jako neuložený návrh.");
}

function exportRegistry() {
  const payload = {
    format: FORMAT,
    version: VERSION,
    app: APP_NAME,
    exportedAt: new Date().toISOString(),
    glyphs: state.registry.glyphs
  };
  const date = new Date().toISOString().slice(0, 10);
  downloadFile(JSON.stringify(payload, null, 2), `glyph-cht-360-zaloha-${date}.json`, "application/json;charset=utf-8");
  state.lastBackupAt = new Date().toISOString();
  renderDrums();
  setStatus("Záloha registru je připravená ke stažení.");
}

async function importRegistry(event) {
  const file = event.target.files?.[0];
  event.target.value = "";
  if (!file) return;
  try {
    const parsed = JSON.parse(await file.text());
    if (!parsed || !Array.isArray(parsed.glyphs)) throw new Error("Soubor nemá seznam Glyphů.");
    const imported = parsed.glyphs.map(hydrateGlyph).filter(Boolean);
    if (!imported.length && parsed.glyphs.length) throw new Error("V záloze nejsou čitelné Glyphy.");
    const message = `Načíst ${imported.length} Glyphů? Shodná ID se aktualizují, ostatní se přidají. Současné zápisy zůstanou zachované.`;
    if (!window.confirm(message)) return;

    const merged = new Map(state.registry.glyphs.map((entry) => [entry.id, entry]));
    imported.forEach((entry) => merged.set(entry.id, entry));
    state.registry.glyphs = [...merged.values()];
    persistRegistry();
    runAudit();
    renderAll();
    setStatus(`Načteno ${imported.length} Glyphů. Případné duplicity ukazuje kontrola.`);
  } catch (error) {
    setStatus(`Zálohu se nepodařilo načíst: ${error.message}`, "error");
  }
}

function setStatus(message, kind = "") {
  dom.statusLine.textContent = message;
  dom.statusLine.dataset.kind = kind;
}

function searchableGlyph(entry) {
  return normalizeSearch([entry.glyph, entry.name, entry.meaning, entry.role, entry.tags.join(" "), worlds[entry.world]].join(" "));
}

function normalizeSearch(value) {
  return normalizeUnicode(String(value || "")).toLocaleLowerCase("cs");
}

function parseTags(value) {
  return String(value || "")
    .split(",")
    .map((tag) => tag.trim())
    .filter(Boolean)
    .slice(0, 24);
}

function sortGlyphs(a, b) {
  const statusOrder = { "schváleno": 0, "návrh": 1, archiv: 2 };
  return (statusOrder[a.status] - statusOrder[b.status]) || b.updatedAt.localeCompare(a.updatedAt);
}

function normalizeUnicode(value) {
  try {
    return String(value).normalize("NFC");
  } catch (error) {
    return String(value);
  }
}

function hasPrivateUseCharacter(value) {
  for (const character of String(value)) {
    const codePoint = character.codePointAt(0);
    if ((codePoint >= 0xe000 && codePoint <= 0xf8ff) || (codePoint >= 0xf0000 && codePoint <= 0xffffd) || (codePoint >= 0x100000 && codePoint <= 0x10fffd)) {
      return true;
    }
  }
  return false;
}

function formatShortDate(value) {
  try {
    return new Intl.DateTimeFormat("cs-CZ", { day: "2-digit", month: "2-digit", hour: "2-digit", minute: "2-digit" }).format(new Date(value));
  } catch (error) {
    return "teď";
  }
}

function formatIssueCount(count) {
  if (count === 1) return "1 chyba";
  if (count >= 2 && count <= 4) return `${count} chyby`;
  return `${count} chyb`;
}

function isDate(value) {
  return Boolean(value) && !Number.isNaN(new Date(value).getTime());
}

function clamp(value, min, max) {
  return Math.min(max, Math.max(min, value));
}

function makeId() {
  if (globalThis.crypto?.randomUUID) return globalThis.crypto.randomUUID();
  return `glyph-${Date.now()}-${Math.random().toString(16).slice(2)}`;
}

function escapeHtml(value) {
  return String(value).replace(/[&<>'"]/g, (character) => ({
    "&": "&amp;",
    "<": "&lt;",
    ">": "&gt;",
    "'": "&#39;",
    "\"": "&quot;"
  })[character]);
}

function escapeAttribute(value) {
  return escapeHtml(value);
}

function downloadFile(contents, filename, type) {
  const blob = new Blob([contents], { type });
  const url = URL.createObjectURL(blob);
  const link = document.createElement("a");
  link.href = url;
  link.download = filename;
  document.body.append(link);
  link.click();
  link.remove();
  window.setTimeout(() => URL.revokeObjectURL(url), 0);
}

async function copyText(text) {
  try {
    if (navigator.clipboard?.writeText) {
      await navigator.clipboard.writeText(text);
      return true;
    }
  } catch (error) {
    // Fallback below keeps copy working in older Safari contexts.
  }

  const textarea = document.createElement("textarea");
  textarea.value = text;
  textarea.setAttribute("readonly", "");
  textarea.style.position = "fixed";
  textarea.style.opacity = "0";
  document.body.append(textarea);
  textarea.select();
  const copied = document.execCommand("copy");
  textarea.remove();
  return copied;
}

function registerServiceWorker() {
  if (!("serviceWorker" in navigator)) return;
  window.addEventListener("load", () => {
    navigator.serviceWorker.register("./sw.js").catch(() => {
      // The app also works when opened directly as a local file.
    });
  });
}
