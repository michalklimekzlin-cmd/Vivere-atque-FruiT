const lifePanel =
  document.getElementById("lifePanel");

const openLifePanel =
  document.getElementById("openLifePanel");

const closeLifePanel =
  document.getElementById("closeLifePanel");

function showLifePanel() {
  lifePanel?.classList.add("open");
  openLifePanel?.classList.add("hidden");
}

function hideLifePanel() {
  lifePanel?.classList.remove("open");
  openLifePanel?.classList.remove("hidden");
}

openLifePanel?.addEventListener(
  "click",
  showLifePanel
);

closeLifePanel?.addEventListener(
  "click",
  hideLifePanel
);

/*
  Po spuštění zůstane panel schovaný,
  aby nepřekrýval paměťové sloty.
*/
hideLifePanel();